#:culture{:id "grc.dish.moussaka", :name "Moussaka", :country "GRC", :kind :dish, :summary "Layered aubergine- or potato-based dish with ground meat; the modern Greek version was created in the 1920s by chef Nikolaos Tselementes, and the dish has many regional variations across the Balkans and Middle East.", :url "https://en.wikipedia.org/wiki/Moussaka", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.dish.souvlaki", :name "Souvlaki", :country "GRC", :kind :dish, :summary "Greek food consisting of small pieces of meat and sometimes vegetables grilled on a skewer, typically eaten as fast food with pita bread.", :url "https://en.wikipedia.org/wiki/Souvlaki", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.dish.greek-salad", :name "Greek salad", :country "GRC", :kind :dish, :summary "Salad in Greek cuisine generally made with pieces of tomatoes, cucumbers, onion, feta cheese and olives, dressed with salt, oregano, lemon juice and olive oil.", :url "https://en.wikipedia.org/wiki/Greek_salad", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.dish.spanakopita", :name "Spanakopita", :country "GRC", :kind :dish, :summary "Savoury spinach pie of Greek origin with a filling of chopped spinach and usually feta or white cheese and egg, eaten throughout Greece.", :url "https://en.wikipedia.org/wiki/Savory_spinach_pie", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.dish.gyros", :name "Gyros", :country "GRC", :kind :dish, :summary "Meat cooked on a vertical rotisserie, sliced and served wrapped or stuffed in pita bread; the Greek variation developed after the 1922-23 population exchange with Turkey.", :url "https://en.wikipedia.org/wiki/Gyros", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.beverage.ouzo", :name "Ouzo", :country "GRC", :kind :beverage, :summary "Dry anise-flavoured aperitif spirit widely consumed in Greece and Cyprus, with EU protected geographical indication restricting production to Greece and Cyprus.", :url "https://en.wikipedia.org/wiki/Ouzo", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.product.feta", :name "Feta", :country "GRC", :kind :product, :summary "Greek brined white cheese made from sheep's milk or a mixture of sheep and goat's milk, with protected designation of origin (PDO) status since 2002.", :url "https://en.wikipedia.org/wiki/Feta", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.festival.patras-carnival", :name "Patras Carnival", :country "GRC", :kind :festival, :summary "The largest carnival event of its kind in Greece, first held in 1829, running from 17 January to Clean Monday with parades and the burning of a carnival-king effigy.", :url "https://en.wikipedia.org/wiki/Patras_Carnival", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.heritage.acropolis-of-athens", :name "Acropolis of Athens", :country "GRC", :kind :heritage, :summary "Ancient citadel above Athens containing the remains of the Parthenon and other historically significant buildings, designated a UNESCO World Heritage Site in 1987.", :url "https://en.wikipedia.org/wiki/Acropolis_of_Athens", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "grc.heritage.delphi", :name "Delphi", :country "GRC", :kind :heritage, :summary "Ancient sacred precinct in central Greece, seat of the Pythia oracle, designated a UNESCO World Heritage Site in 1987.", :url "https://en.wikipedia.org/wiki/Delphi", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
